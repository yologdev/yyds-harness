def _line_shows_title_resolution(line: str, task_title: str) -> bool:
    """Return True if line shows resolution language related to task title even without task keys."""
    lower = line.lower()
    # Session-date prefix with resolution
    if re.match(r"day\s+\d+", lower) and any(
        signal in lower for signal in _RESOLUTION_SIGNALS
    ):
        return True
    if not any(signal in lower for signal in _RESOLUTION_SIGNALS):
        return False
    # Match via task title words
    title_lower = task_title.lower()
