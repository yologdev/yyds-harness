pub(crate) fn try_dispatch_subcommand(args: &[String]) -> Option<Option<Config>> {
    // Only short-circuit --help/--version when there's no subcommand in args[1].
    // If args[1] is a subcommand (e.g., "state"), let the match arm handle --help.
    let args1_is_flag = args.get(1).map_or(true, |s| s.starts_with('-'));
    if args1_is_flag {
        if args.iter().any(|a| a == "--help" || a == "-h") {
            print_help();
            return Some(None);
        }
        if args.iter().any(|a| a == "--version" || a == "-V") {
            println!("{}", crate::commands_info::version_line());
            return Some(None);
        }
    }

    if let Some(sub) = args.get(1) {
        match sub.as_str() {
            // ...
        }
    }

    None
}
```

