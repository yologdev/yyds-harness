        let raw = std::fs::read_to_string(&events_path).unwrap();
        assert!(
            raw.contains("RunCompleted"),
            "should contain RunCompleted: {raw}"
        );
        assert!(
            raw.contains("rust_panic"),
            "should contain rust_panic: {raw}"
        );
    }
