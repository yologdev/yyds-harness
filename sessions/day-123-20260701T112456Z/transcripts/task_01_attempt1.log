```rust
const MAX_CACHE_REPORT_EVENTS: usize = 20_000;

fn read_tail_lines(path: &Path, cap: usize) -> Result<(Vec<String>, usize, usize), std::io::Error> {
    let raw = std::fs::read_to_string(path)?;
    let total: usize = raw.lines().count();
    
    let lines: Vec<String> = {
        let mut deque = VecDeque::new();
        for line in raw.lines() {
            deque.push_back(line.to_string());
            if deque.len() > cap {
                deque.pop_front();
            }
        }
        deque.into_iter().collect()
    };
    let scanned = lines.len();
    
    Ok((lines, total, scanned))
}
```

Then in `handle_cache_report`:
- Call `read_tail_lines` with the cap
- Parse the lines as JSON values
- Build cache report
- If capped, add truncation note

