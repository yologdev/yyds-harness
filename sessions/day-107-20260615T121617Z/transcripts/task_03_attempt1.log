```python
def is_task_contradicted(task, assessment):
    """Check if the assessment shows the task's problem is already resolved."""
    lower = assessment.lower()
    task_keys = task.get("keys", ())
    recent_changes, self_tests = extract_recent_changes_and_self_tests(assessment)
    
    # Check Recent Changes for resolution of task domain
    resolved_patterns = [
        r"(now|already|no longer)\s+(properly |correctly )?(explains |reports |shows |handles |works )",
        r"(fixed|resolved|addressed|landed|closed|shipped)\s+(the )?",
        r"(improved|patched|repaired|polished)\s+(the )?",
    ]
    
    for line in recent_changes.splitlines():
        for key in task_keys:
            if key.lower() in line.lower():
                for pat in resolved_patterns:
                    if re.search(pat, line.lower()):
                        return True, f"assessment says '{key}' is resolved: {line.strip()}"
    
    # Check Self-Test Results for passing tests in task domain
    for line in self_tests.splitlines():
        if "✅" not in line and "pass" not in line.lower():
            continue
        for key in task_keys:
            if key.lower() in line.lower():
                return True, f"self-test shows '{key}' already works: {line.strip()}"
    
    return False, ""
```

