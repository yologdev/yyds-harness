Now let me plan the `check_task_has_evidence` function:

```rust
/// Check whether a task has concrete verifiable evidence: either terminal evidence
/// markers in the task log (TASK_TERMINAL_EVIDENCE: changed|obsolete|blocked) or
/// actual source file modifications.
fn check_task_has_evidence(task_log: &Path, task_git_base: Option<&str>) -> bool {
    // 1. Check for terminal evidence markers in the task log
    if let Ok(content) = std::fs::read_to_string(task_log) {
        // Look for TASK_TERMINAL_EVIDENCE: changed|obsolete|blocked
        let re = regex::Regex::new(r"TASK_TERMINAL_EVIDENCE:\s*(changed|obsolete|blocked)").ok();
        if let Some(re) = re {
            if re.is_match(&content) {
                return true;
            }
        }
    }
    
    // 2. Check for git diff evidence if task_git_base is provided
    if let Some(base) = task_git_base {
        // Check if there are any changes since the base commit
        if let Ok(output) = Command::new("git")
            .args(["diff", "--name-only", base, "HEAD", "--", "src/", "Cargo.toml", "Cargo.lock"])
            .output()
        {
            if output.status.success() {
                let diff_files = String::from_utf8_lossy(&output.stdout);
                if !diff_files.trim().is_empty() {
                    return true;
                }
            }
        }
        // Also check staged changes
        if let Ok(output) = Command::new("git")
            .args(["diff", "--cached", "--name-only", "--", "src/", "Cargo.toml", "Cargo.lock"])
            .output()
        {
            if output.status.success() {
                let staged = String::from_utf8_lossy(&output.stdout);
                if !staged.trim().is_empty() {
                    return true;
                }
            }
        }
    }
    
    false
}
```

