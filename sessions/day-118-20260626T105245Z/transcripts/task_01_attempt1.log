```python
def _title_significant_words(title: str) -> list[str]:
    """Extract significant words from a task title (skip common generic words)."""
    STOP = {"make", "fix", "add", "improve", "enable", "support", "implement", 
            "task", "tasks", "the", "a", "an", "for", "in", "on", "to", "of"}
    words = title.lower().split()
    return [w for w in words if w not in STOP and len(w) > 2]
```

