I'll add a `task_title` parameter and a title-based check. Here's my plan:

```python
def _line_shows_resolution(line: str, task_keys: tuple[str, ...], task_title: str = "") -> bool:
    """Return True if line indicates a task-key problem is already resolved."""
    lower = line.lower()
    # Check task keys
    key_match = any(key in lower for key in task_keys)
    # Also check significant title words
    title_match = task_title and _title_words_match_line(lower, task_title)
    if not key_match and not title_match:
        return False
    # Session-date prefix (Day NNN) describing work already completed
    if re.match(r"day\s+\d+", lower):
        return True
    return any(signal in lower for signal in _RESOLUTION_SIGNALS)
```

And I need a helper `_title_words_match_line`:
```python
def _title_words_match_line(lower: str, title: str) -> bool:
    """Return True if enough significant words from title appear in lower line."""
    STOP = frozenset({"make", "fix", "add", "improve", "enable", "support", 
                      "implement", "task", "tasks", "the", "a", "an", "for", 
                      "in", "on", "to", "of", "and", "or", "not"})
    words = [w for w in title.lower().split() if w not in STOP and len(w) > 2]
    if len(words) < 2:
        return False
    # Need at least 2 significant words to match to avoid false positives
    matches = sum(1 for w in words if w in lower)
    return matches >= 2
```

