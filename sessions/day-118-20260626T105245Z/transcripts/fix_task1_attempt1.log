### `_line_shows_obsolete_or_reverted(line, task_keys, task_title)`:
```python
def _line_shows_obsolete_or_reverted(line: str, task_keys: tuple[str, ...], task_title: str) -> bool:
    """Return True if line indicates a task's domain was marked obsolete/reverted."""
    lower = line.lower()
    markers = (
        "marked obsolete",
        "obsolete_already_satisfied",
        "reverted_no_edit",
        "reverted — no edit",
        "reverted — no",
        "criteria already satisfied",
        "reverted without",
    )
    if not any(m in lower for m in markers):
        return False
    # The line must reference this task somehow — via keys or title words
    if any(key in lower for key in task_keys):
        return True
    # Also match significant words from the task title
    title_lower = task_title.lower()
    # Check if a meaningful phrase from the title appears in the line
    title_words = title_lower.split()
    # Look for multi-word phrases from the title
    for phrase_len in (3, 2, 1):
        for i in range(len(title_words) - phrase_len + 1):
            phrase = " ".join(title_words[i:i + phrase_len])
            if len(phrase) > 5 and phrase in lower:
                return True
    return False
```

