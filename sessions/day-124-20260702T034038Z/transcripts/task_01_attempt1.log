Let me implement a seek-based tail reader. Here's the plan:

```rust
fn read_tail(path: &Path, limit: usize) -> Result<Vec<String>, std::io::Error> {
    use std::io::{BufRead, BufReader, Read, Seek, SeekFrom};
    
    let file = std::fs::File::open(path)?;
    let file_size = file.metadata()?.len();
    
    // Estimate: each line is ~200 bytes, read enough to cover limit lines + safety margin
    let est_bytes_needed = (limit as u64 * 512).min(file_size);
    let read_start = file_size.saturating_sub(est_bytes_needed);
    
    let mut file = std::fs::File::open(path)?;
    file.seek(SeekFrom::Start(read_start))?;
    
    let mut buf = String::new();
    file.read_to_string(&mut buf)?;
    
    // If we started mid-file, skip the first partial line
    let lines: Vec<String> = if read_start > 0 {
        buf.lines()
            .skip(1) // skip partial first line
            .map(|s| s.to_string())
            .collect()
    } else {
        buf.lines().map(|s| s.to_string()).collect()
    };
    
    // If we didn't get enough lines, we might need to read more
    // But for now, just take the last `limit` lines
    if lines.len() <= limit {
        Ok(lines)
    } else {
        Ok(lines[lines.len() - limit..].to_vec())
    }
}
```

