The fix for `read_tail` is the key change. Here's my plan:

```rust
fn read_tail(path: &Path, limit: usize) -> Result<Vec<String>, std::io::Error> {
    use std::io::{BufRead, BufReader, Read, Seek, SeekFrom};
    
    let file = std::fs::File::open(path)?;
    let file_size = file.metadata()?.len();
    
    // Estimate: assume each line is ~512 bytes (conservative for JSONL)
    // Read enough to cover `limit` lines plus a safety margin
    let est_bytes_per_line = 512u64;
    let est_bytes_needed = (limit as u64 * est_bytes_per_line).min(file_size);
    let mut read_start = file_size.saturating_sub(est_bytes_needed);
    
    let mut attempt = 0;
    const MAX_ATTEMPTS: usize = 4;
    
    loop {
        let mut file = std::fs::File::open(path)?;
        file.seek(SeekFrom::Start(read_start))?;
        let mut buf = String::new();
        file.read_to_string(&mut buf)?;
        
        let lines: Vec<String> = if read_start > 0 {
            // Skip the first partial line
            buf.lines()
                .skip(1)
                .map(|s| s.to_string())
                .collect()
        } else {
            buf.lines().map(|s| s.to_string()).collect()
        };
        
        if lines.len() >= limit || read_start == 0 || attempt >= MAX_ATTEMPTS {
            // Return at most `limit` lines
            if lines.len() <= limit {
                return Ok(lines);
            } else {
                return Ok(lines[lines.len() - limit..].to_vec());
            }
        }
        
        // Not enough lines, go back further
        let factor = 2u64.pow((attempt + 1) as u32);
        read_start = file_size.saturating_sub(est_bytes_needed * factor);
        attempt += 1;
    }
}
```

