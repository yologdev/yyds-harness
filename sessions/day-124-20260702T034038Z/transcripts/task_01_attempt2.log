Here's my implementation plan for `read_tail`:

```rust
fn read_tail(path: &Path, limit: usize) -> Result<Vec<String>, std::io::Error> {
    use std::io::{BufRead, BufReader, Read, Seek, SeekFrom};
    
    let file = std::fs::File::open(path)?;
    let file_size = file.metadata()?.len();
    
    if file_size == 0 {
        return Ok(Vec::new());
    }
    
    // Conservative estimate: 1KB per line for JSONL events.
    // Read enough to cover `limit` lines with margin.
    let est_bytes_per_line: u64 = 1024;
    let needed = (limit as u64).saturating_mul(est_bytes_per_line);
    let mut read_start = file_size.saturating_sub(needed);
    
    // Try up to 4 times with progressively larger windows
    for attempt in 0..4u32 {
        let mut f = std::fs::File::open(path)?;
        f.seek(SeekFrom::Start(read_start))?;
        
        let mut buf = String::new();
        f.read_to_string(&mut buf)?;
        
        let lines: Vec<String> = if read_start > 0 {
            // Skip the first partial line (we started mid-line)
            buf.lines()
                .skip(1)
                .map(|s| s.to_string())
                .collect()
        } else {
            buf.lines().map(|s| s.to_string()).collect()
        };
        
        if lines.len() >= limit || read_start == 0 {
            if lines.len() <= limit {
                return Ok(lines);
            }
            return Ok(lines[lines.len() - limit..].to_vec());
        }
        
        // Need more lines, go back further
        read_start = file_size.saturating_sub(needed * 2u64.pow(attempt + 1));
    }
    
    // Fallback: read the whole file
    let raw = std::fs::read_to_string(path)?;
    let mut lines = VecDeque::new();
    for line in raw.lines() {
        lines.push_back(line.to_string());
        if lines.len() > limit {
            lines.pop_front();
        }
    }
    Ok(lines.into_iter().collect())
}
```

