```rust
#[test]
fn why_report_suggests_alternatives_when_no_failure_found() {
    // Case 1: empty events - should mention tail
    let events = vec![];
    let err = build_why_report(&events, "last-failure").unwrap_err();
    assert!(err.contains("no state event found for 'last-failure'"));
    assert!(err.contains("state tail"));
    
    // Case 2: all green - should mention crashes and last-crash
    let events = vec![
        event("evt-1", "RunStarted", "run-1", json!({"task": "x"})),
        event("evt-2", "RunCompleted", "run-1", json!({"status": "success"})),
    ];
    let err = build_why_report(&events, "last-failure").unwrap_err();
    assert!(err.contains("successful"));
    assert!(err.contains("state crashes"));
    assert!(err.contains("state why last-crash"));
    
    // Case 3: active incomplete run
    let events = vec![
        event("evt-1", "RunStarted", "run-1", json!({"task": "x"})),
    ];
    let err = build_why_report(&events, "last-failure").unwrap_err();
    assert!(err.contains("in progress"));
}
```

