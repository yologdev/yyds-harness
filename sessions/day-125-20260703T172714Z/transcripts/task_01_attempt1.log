def _assessment_missing_fallback() -> dict[str, object]:
    """Return the smallest-scope concrete task from TASKS when assessment is missing."""
    # Collect tasks with clear verifiers and ≤2 files
    narrow = []
    for task in TASKS:
        if _has_protected_files(task):
            continue
        if not _candidate_files_exist(task):
            continue
        fc = _task_file_count(task)
        if fc > 2:
            continue
        # Skip diagnostic/analysis tasks (those with "investigate", "analyze", "diagnostic" in title or objective)
        title_lower = str(task.get("title", "")).lower()
        obj_lower = str(task.get("objective", "")).lower()
        if any(w in title_lower or w in obj_lower for w in ("investigate", "diagnose", "diagnostic", "analyze why")):
            continue
        narrow.append((fc, task))
    if narrow:
        narrow.sort(key=lambda x: x[0])
        return narrow[0][1]
    # Ultimate fallback: a concrete single-file task
    return {
        "title": "Fix a yyds state or tool reliability regression",
        "files": "src/state.rs",
        ...
    }
```

