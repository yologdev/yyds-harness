    diff = git(repo, ["diff", "--cached", "--quiet"])
    if diff.returncode == 0:
        return {"attempted": True, "ok": True, "reason": "no staged source changes after git add"}
    commit = git(repo, ["commit", "-m", message])
    ...
```

