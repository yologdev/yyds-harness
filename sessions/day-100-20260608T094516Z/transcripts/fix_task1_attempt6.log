```rust
fn hash_term_to_vector(term: &str, dimensions: usize) -> Vec<f32> {
    use std::hash::{Hash, Hasher};
    use std::collections::hash_map::DefaultHasher;
    
    let mut vec = vec![0.0f32; dimensions];
    
    // Generate a seed from the term
    let mut hasher = DefaultHasher::new();
    term.hash(&mut hasher);
    let mut state: u64 = hasher.finish();
    
    for i in 0..dimensions {
        // xorshift64
        state ^= state << 13;
        state ^= state >> 7;
        state ^= state << 17;
        // Map to ~[-1, 1] range
        vec[i] = ((state as f64) / (u64::MAX as f64)) as f32 * 2.0 - 1.0;
    }
    
    // Normalize to unit length
    let norm: f32 = vec.iter().map(|v| v * v).sum::<f32>().sqrt();
    if norm > 0.0 {
        for v in &mut vec {
            *v /= norm;
        }
    }
    
    vec
}
```

This is clean, deterministic, and requires no new module-level imports (the `use` statements are inside the function).

