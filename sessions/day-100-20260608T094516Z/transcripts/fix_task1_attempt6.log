```rust
fn build_persistent_embedding_index(
    semantic_index: &PersistentSemanticIndex,
) -> Result<PersistentEmbeddingIndex, String> {
    const DIMENSIONS: usize = 128;
    
    // Collect all unique terms and assign them hash-based vectors
    let mut term_map: BTreeMap<String, Vec<f32>> = BTreeMap::new();
    let mut all_terms: Vec<String> = Vec::new();
    
    for file in &semantic_index.files {
        for term in &file.terms {
            if !term_map.contains_key(term) {
                let vector = hash_term_to_vector(term, DIMENSIONS);
                term_map.insert(term.clone(), vector);
                all_terms.push(term.clone());
            }
        }
    }
    
    // Build term entries
    let terms: Vec<PersistentEmbeddingIndexTerm> = all_terms.into_iter().map(|term| {
        let embedding = term_map.remove(&term).unwrap();
        PersistentEmbeddingIndexTerm { term, embedding }
    }).collect();
    
    // Build file embeddings (average of term vectors)
    let mut files = Vec::new();
    for file in &semantic_index.files {
        if file.terms.is_empty() {
            continue;
        }
        let vectors: Vec<&[f32]> = file.terms.iter()
            .filter_map(|t| terms.iter().find(|e| e.term == *t).map(|e| e.embedding.as_slice()))
            .collect();
        if vectors.is_empty() {
            continue;
        }
        let file_embedding = average_embedding_vectors(&vectors)
            .unwrap_or_else(|| vec![0.0; DIMENSIONS]);
        files.push(PersistentEmbeddingIndexFile {
            path: file.path.clone(),
            len_bytes: file.len_bytes,
            modified_ms: file.modified_ms,
            embedding: file_embedding,
        });
    }
    
    Ok(PersistentEmbeddingIndex {
        schema_version: EMBEDDING_INDEX_SCHEMA_VERSION,
        generated_at_ms: now_ms(),
        files,
        terms,
    })
}

fn hash_term_to_vector(term: &str, dimensions: usize) -> Vec<f32> {
    // Use a simple hash-based random projection
    use std::collections::hash_map::DefaultHasher;
    use std::hash::{Hash, Hasher};
    
    let mut vec = vec![0.0f32; dimensions];
    let mut hasher = DefaultHasher::new();
    term.hash(&mut hasher);
    let seed = hasher.finish();
    
    // Generate sparse random vector using the hash as seed
    // Use xorshift to generate pseudo-random values deterministically
    let mut state = seed;
    for i in 0..dimensions {
        state ^= state << 13;
        state ^= state >> 7;
        state ^= state << 17;
        // Map to [-1.0, 1.0]
        let val = ((state as f64) / (u64::MAX as f64)) as f32 * 2.0 - 1.0;
        vec[i] = val;
    }
    
    // Normalize to unit length
    let norm: f32 = vec.iter().map(|v| v * v).sum::<f32>().sqrt();
    if norm > 0.0 {
        for v in &mut vec {
            *v /= norm;
        }
    }
    
    vec
}
```

