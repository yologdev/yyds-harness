```rust
    // --- Claims ---
    let claim_line = if store_path.exists() {
        match Connection::open(&store_path) {
            Ok(conn) => {
                let run_started: i64 = conn
                    .query_row(
                        "SELECT COUNT(*) FROM state_events WHERE event_type = 'RunStarted'",
                        [],
                        |row| row.get(0),
                    )
                    .unwrap_or(0);
                let run_completed: i64 = conn
                    .query_row(
                        "SELECT COUNT(*) FROM state_events WHERE event_type = 'RunCompleted'",
                        [],
                        |row| row.get(0),
                    )
                    .unwrap_or(0);
                let model_started: i64 = conn
                    .query_row(
                        "SELECT COUNT(*) FROM state_events WHERE event_type = 'ModelCallStarted'",
                        [],
                        |row| row.get(0),
                    )
                    .unwrap_or(0);
                let model_completed: i64 = conn
                    .query_row(
                        "SELECT COUNT(*) FROM state_events WHERE event_type = 'ModelCallCompleted'",
                        [],
                        |row| row.get(0),
                    )
                    .unwrap_or(0);

                // run lifecycle claims: each RunStarted claim needs a RunCompleted
                let run_total = run_started;
                let run_proven = run_completed.min(run_started);
                let run_missing = run_started.saturating_sub(run_completed);

                // model lifecycle claims: each ModelCallStarted claim needs a ModelCallCompleted
                let model_total = model_started;
                let model_proven = model_completed.min(model_started);
                let model_missing = model_started.saturating_sub(model_completed);

                let total_claims = run_total + model_total;
                let proven = run_proven + model_proven;
                let missing = run_missing + model_missing;
                let observed = 0; // no observed-but-unproven in this simple view
                let non_proven = total_claims - proven;

                let ratio = if total_claims > 0 {
                    proven as f64 / total_claims as f64
                } else {
                    1.0
                };
                let claim_color = if ratio >= 0.9 {
                    &GREEN
                } else if ratio >= 0.7 {
                    &YELLOW
                } else {
                    &RED
                };

                let mut parts = vec![format!(
                    "{claim_color}  Claims:    {proven}/{total_claims} proven ({ratio:.0}%){RESET}"
                )];
                if non_proven > 0 {
                    parts.push(format!("{RUN}  Non-proven: {non_proven} ({missing} missing){RESET}"));
                    if run_missing > 0 {
                        parts.push(format!(
                            "  {YELLOW}  run_lifecycle: {run_proven}/{run_total} proven ({run_missing} missing){RESET}"
                        ));
                    }
                    if model_missing > 0 {
                        parts.push(format!(
                            "  {YELLOW}  model_lifecycle: {model_proven}/{model_total} proven ({model_missing} missing){RESET}"
                        ));
                    }
                }
                parts.join("\n")
            }
            Err(e) => {
                format!("{RED}  Claims:    cannot open store: {e}{RESET}")
            }
        }
    } else {
        format!("{YELLOW}  Claims:    store not present — claim data unavailable{RESET}")
    };
    println!("{claim_line}");
```

