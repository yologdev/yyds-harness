```python
def _implementation_passed_build_and_test(transcript_text: str) -> bool:
    """Check if the implementation transcript shows passing cargo build and test."""
    if not transcript_text:
        return False
    
    # Find cargo build commands and check they succeeded
    build_passed = _cargo_build_passed(transcript_text)
    test_passed = _cargo_test_passed(transcript_text)
    
    return build_passed and test_passed

def _cargo_build_passed(text: str) -> bool:
    """Check if cargo build succeeded in the transcript."""
    # Look for cargo build/check commands followed by success indicators
    # Pattern: cargo build/check command, then "Finished" without intervening errors
    build_cmd = re.compile(r'cargo\s+(build|check)\b', re.IGNORECASE)
    finished_re = re.compile(r'\bFinished\s+\w+\s+', re.IGNORECASE)
    error_re = re.compile(r'^\s*error(\[|:)', re.IGNORECASE | re.MULTILINE)
    
    for match in build_cmd.finditer(text):
        # Get the next ~500 chars after the command
        start = match.start()
        window = text[start:start + 800]
        # Check if "Finished" appears and no "error:" in the window
        # But we need to be more careful - the error could be from a different command
        # Let's check if Finished appears before the next "cargo" command or end of window
        finished_pos = window.find("Finished")
        if finished_pos != -1:
            # Check no error between the cargo command and Finished
            before_finished = window[:finished_pos]
            # Also check there's no error in the whole build output up to next command
            next_cargo = re.search(r'\bcargo\b', window[10:])  # skip the current match
            end = next_cargo.start() + 10 if next_cargo else len(window)
            segment = window[:end]
            if not error_re.search(segment):
                return True
    return False

def _cargo_test_passed(text: str) -> bool:
    """Check if cargo test succeeded in the transcript."""
    # Look for cargo test commands followed by "test result: ok"
    test_cmd = re.compile(r'cargo\s+test\b', re.IGNORECASE)
    ok_re = re.compile(r'test result:\s*ok', re.IGNORECASE)
    
    for match in test_cmd.finditer(text):
        start = match.start()
        # Get window after the cargo test command
        window = text[start:start + 1500]
        next_cargo = re.search(r'\bcargo\b', window[10:])  # skip current match
        end = next_cargo.start() + 10 if next_cargo else len(window)
        segment = window[:end]
        if ok_re.search(segment):
            return True
    return False
```

