```python
def test_manifest_detects_cross_reference_mismatch(self):
    with tempfile.TemporaryDirectory() as tmp:
        root = Path(tmp)
        plan = root / "session_plan"
        plan.mkdir()
        (plan / "assessment.md").write_text("# Assessment\nState feedback.\n", encoding="utf-8")
        (plan / "task_01.md").write_text(
            """Title: Fix something in the harness
Files: scripts/preseed_session_plan.py
Issue: none
Origin: planner

Objective:
Analyze the harness dispatching logic in scripts/evolve.sh and improve scripts/build_evolution_dashboard.py.

Why this matters:
Cross-reference mismatches cause verifier rejection.

Success Criteria:
- scripts/evolve.sh is analyzed

Verification:
- python3 -m unittest

Expected Evidence:
- task verification rate improves
""",
            encoding="utf-8",
        )
        args = type(
            "Args",
            (),
            {
                "session_plan_dir": plan,
                "assessment_file": plan / "assessment.md",
                "assessment_missing_file": plan / "assessment_missing.md",
                "issue_responses_file": plan / "issue_responses.md",
                "planning_failure_file": plan / "planning_failure.md",
                "selected_limit": 3,
                "planning_failed": False,
            },
        )()

        manifest = task_manifest.build_manifest(args)
        
        task = manifest["tasks"][0]
        quality = task["quality"]
        undeclared = quality.get("undeclared_file_mentions", [])
        self.assertIn("scripts/evolve.sh", undeclared)
        self.assertIn("scripts/build_evolution_dashboard.py", undeclared)
        self.assertLess(quality["score"], 1.0)
        
        # Check warning
        warnings = manifest.get("warnings") or []
        self.assertIn("task_01:cross_reference_mismatch", warnings)
```

