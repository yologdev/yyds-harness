And the recovery task function:

```python
def _landable_recovery_task() -> dict[str, object] | None:
    """Return the smallest landable src/*.rs task from TASKS."""
    # Find the task with the fewest src/*.rs files
    src_tasks = [t for t in TASKS if _has_src_files(t)]
    if not src_tasks:
        return None
    src_tasks.sort(key=_task_file_count)
    # Prefer the tool-path recovery task (1 file, well-scoped) or the
    # run-completion-guard task (1 file) as the most landable options.
    for title in (
        "Add recovery hints for common tool-path and permission errors",
        "Stabilize run completion guard panic test",
    ):
        for t in src_tasks:
            if t["title"] == title:
                return dict(t)
    return dict(src_tasks[0])
```

