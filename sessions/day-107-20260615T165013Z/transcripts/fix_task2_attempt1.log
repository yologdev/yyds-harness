fn model_lifecycle_key(event: &Value) -> String {
    event_string(event, "run_id")
        .filter(|run_id| !run_id.is_empty())
        .or_else(|| event_string(event, "event_id"))
        .unwrap_or("-")
        .to_string()
}
```

