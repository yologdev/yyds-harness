```rust
fn read_events_lenient(path: &Path) -> Result<(Vec<Value>, usize), std::io::Error> {
    let raw = std::fs::read_to_string(path)?;
    let mut events = Vec::new();
    let mut skipped = 0;

    for line in raw.lines().filter(|line| !line.trim().is_empty()) {
        let parsed = crate::state::compatibility_event_json_line(line)
            .ok()
            .and_then(|normalized| serde_json::from_str::<Value>(&normalized).ok())
            .or_else(|| serde_json::from_str::<Value>(line).ok());
        match parsed {
            Some(value) => events.push(value),
            None => skipped += 1,
        }
    }

    Ok((events, skipped))
}
```

The function:
1. Reads the file to string
2. For each non-empty line, tries `compatibility_event_json_line` first (which normalizes), then falls back to raw JSON parse
3. If neither works, increments skipped

