```rust
fn close_orphaned_run(events_path: &Path, store_path: Option<&Path>) -> Result<(), String> {
    // Read the last N events
    if !events_path.exists() {
        return Ok(());
    }
    
    let raw = std::fs::read_to_string(events_path)
        .map_err(|e| format!("read state events '{}': {e}", events_path.display()))?;
    
    let events: Vec<Value> = raw.lines()
        .filter(|l| !l.trim().is_empty())
        .filter_map(|line| serde_json::from_str::<Value>(line).ok())
        .collect();
    
    // Check last ~20 events for an orphaned RunStarted
    let tail_start = if events.len() > 20 { events.len() - 20 } else { 0 };
    let tail = &events[tail_start..];
    
    // Find the last RunStarted
    let mut last_run_started = None;
    for event in tail.iter().rev() {
        let event_type = event.get("event_type").or_else(|| event.get("kind"))
            .and_then(|v| v.as_str()).unwrap_or("");
        if event_type == "RunStarted" {
            last_run_started = Some(event);
            break;
        }
        if event_type == "RunCompleted" {
            // If we find a RunCompleted before RunStarted, the last run is closed
            break;
        }
    }
    
    if let Some(run_started) = last_run_started {
        // Check if there's a matching RunCompleted
        let orphaned_run_id = run_started.get("run_id").and_then(|v| v.as_str());
        if let Some(rid) = orphaned_run_id {
            // Check if there's already a RunCompleted for this run_id
            let has_completed = tail.iter().any(|e| {
                let et = e.get("event_type").or_else(|| e.get("kind"))
                    .and_then(|v| v.as_str()).unwrap_or("");
                let r_id = e.get("run_id").and_then(|v| v.as_str()).unwrap_or("");
                et == "RunCompleted" && r_id == rid
            });
            
            if !has_completed {
                // Emit RunCompleted for the orphaned run
                let event = StateEvent {
                    event_id: format!("evt-orphan-closure-{}", rid),
                    event_type: EventType::RunCompleted,
                    schema_version: STATE_SQLITE_SCHEMA_VERSION,
                    timestamp_ms: now_ms(),
                    actor: Actor::Harness,
                    run_id: Some(rid.to_string()),
                    session_id: None,
                    trace_id: format!("trace-orphan-{}", rid),
                    parent_event_ids: Vec::new(),
                    payload: json!({
                        "status": "error",
                        "error": "previous run did not complete (orphaned)",
                        "completed_at_ms": now_ms(),
                    }),
                };
                append_event_with_projection(events_path, store_path, &event)?;
            }
        }
    }
    
    Ok(())
}
```

