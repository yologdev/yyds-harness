Let me design the approach:

```python
def task_scope_mismatch(row: dict[str, Any]) -> bool:
    """Returns True only for genuine source-edit scope mismatches (not external-only tasks)."""
    problems = row.get("problems") if isinstance(row.get("problems"), list) else []
    if "no_planned_file_overlap" not in problems:
        return False
    # External-only tasks (planned "none") aren't genuine scope violations
    if external_only_planned(row.get("planned_files") or []):
        return False
    return True

def task_external_only_mismatch(row: dict[str, Any]) -> bool:
    """Returns True when an external-only task has no_planned_file_overlap (missing/invalid evidence)."""
    problems = row.get("problems") if isinstance(row.get("problems"), list) else []
    if "no_planned_file_overlap" not in problems:
        return False
    return external_only_planned(row.get("planned_files") or [])
```

