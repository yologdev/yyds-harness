```rust
#[test]
fn run_completion_guard_reports_error_on_panic() {
    let dir = tempfile::tempdir().unwrap();
    let events_path = dir.path().join("events.jsonl");
    let config = StateConfig {
        enabled: true,
        fail_soft: true,
        events_path: events_path.clone(),
        store_path: None,
    };
    init_global(config, json!({})).unwrap();

    // Simulate what the panic hook does: record FailureObserved + set RUN_HAD_ERROR
    RUN_HAD_ERROR.with(|c| c.set(true));
    record(
        EventType::FailureObserved,
        Actor::Harness,
        json!({"failure_class": "rust_panic", "panic_message": "test lifecycle error 107"}),
    );

    // Then drop the guard — it should read RUN_HAD_ERROR and record "error" status
    {
        let _guard = RunCompletionGuard::completed_on_drop();
    }

    let raw = std::fs::read_to_string(&events_path).unwrap();
    assert!(raw.contains("RunStarted"));
    assert!(raw.contains("FailureObserved"));
    assert!(raw.contains("RunCompleted"));
    assert!(raw.contains("\"status\":\"error\""));
    assert!(!raw.contains("\"status\":\"completed\""));
}
```

This approach:
- No `catch_unwind`, no `install_panic_hook`, no `Once` guard
- No actual panic — no thread spawning during unwind
- Still verifies the full chain: FailureObserved recorded, RUN_HAD_ERROR set, guard drops with error status
- Deterministic

