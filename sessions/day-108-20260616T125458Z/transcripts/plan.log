fn read_tail_events(path: &Path, limit: usize) -> Result<Vec<Value>, std::io::Error> {
    if limit == 0 {
        return read_events(path);
    }
    let raw_lines = read_tail(path, limit)?;  // Just reads lines as strings
    let mut events = Vec::with_capacity(raw_lines.len());
    for line in &raw_lines {
        if let Ok(value) = serde_json::from_str::<Value>(line) {  // Skips bad lines!
            events.push(value);
        }
    }
    Ok(events)
}
```

