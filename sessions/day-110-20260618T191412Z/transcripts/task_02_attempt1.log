        Ok(events) => events,
        Err(_) => {
            match read_events_from_sqlite(&path) {
                Ok(events) => events,
                Err(e) => {
                    eprintln!("{YELLOW}  no state log found at {} ({e}){RESET}", path.display());
                    return;
                }
            }
        }
    };
    // rest unchanged
}
```

