### 1. `deepseek.rs`: Modify `record_json_output_failure` to also emit `FailureObserved`

```rust
pub fn record_json_output_failure(failure: &JsonOutputFailure) {
    // Record the specific JsonOutputFailure event
    crate::state::record(
        crate::state::EventType::JsonOutputFailure,
        crate::state::Actor::Harness,
        failure.to_state_payload(),
    );
    // Also emit a FailureObserved event for aggregation
    let policy = active_harness_genome().json_policy;
    if policy.record_failure_event {
        crate::state::record(
            crate::state::EventType::FailureObserved,
            crate::state::Actor::Harness,
            json!({
                "source": format!("deepseek::json_output::{}", failure.source),
                "message": format!(
                    "JSON output parsing failed after {} attempt(s){}{}",
                    failure.attempts.len(),
                    if failure.retry_allowed { " (retry allowed)" } else { "" },
                    failure.schema_name.as_deref().map_or(String::new(), |n| format!(" for schema '{}'", n)),
                ),
                "class": "json_parse",
                "retryable": failure.retry_allowed,
                "attempts": failure.attempts,
                "error_preview": failure.attempts.last().and_then(|a| a.error_preview.as_deref()).unwrap_or("unknown"),
            }),
        );
    }
}
```

### 2. `deepseek.rs`: Add `record_strict_schema_failure` function

```rust
pub fn record_strict_schema_failure(report: &ToolSchemaValidationReport, retry_allowed: bool) {
    crate::state::record(
        crate::state::EventType::FailureObserved,
        crate::state::Actor::Harness,
        json!({
            "source": "deepseek::schema_validation",
            "message": format!(
                "strict tool schema validation failed for '{}': missing_required=[{}], unexpected_fields=[{}], type_errors=[{}], enum_errors=[{}]",
                report.schema_name,
                report.missing_required.join(", "),
                report.unexpected_fields.join(", "),
                report.type_errors.join(", "),
                report.enum_errors.join(", "),
            ),
            "class": "schema",
            "retryable": retry_allowed,
            "schema_name": report.schema_name,
            "error_preview": report.repair_instruction.as_deref().unwrap_or("strict tool schema validation failed"),
        }),
    );
}
```

