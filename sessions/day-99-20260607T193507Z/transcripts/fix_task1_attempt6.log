### Implementation approach:

For #1, I'll modify `record_json_output_failure` to also emit `FailureObserved`:
```rust
pub fn record_json_output_failure(failure: &JsonOutputFailure) {
    crate::state::record(
        crate::state::EventType::JsonOutputFailure,
        crate::state::Actor::Harness,
        failure.to_state_payload(),
    );
    // Also emit FailureObserved for the state subsystem
    crate::state::record(
        crate::state::EventType::FailureObserved,
        crate::state::Actor::Harness,
        json!({
            "source": "deepseek::json_parse",
            "message": format!("JSON output parsing failed for {}: {} attempts", 
                failure.source,
                failure.attempts.len()),
            "class": "json_parse",
            "retryable": failure.retry_allowed,
            "details": failure.to_state_payload(),
        }),
    );
}
```

For #2, I'll add:
```rust
pub fn record_tool_schema_repair_failure(decision: &ToolSchemaRepairDecision) {
    if !decision.should_record_failure {
        return;
    }
    crate::state::record(
        crate::state::EventType::FailureObserved,
        crate::state::Actor::Harness,
        json!({
            "source": "deepseek::schema_validation",
            "message": decision.reason,
            "class": "schema",
            "retryable": false,
            "schema_name": decision.schema_name,
            "failed_attempt": decision.failed_attempt,
            "max_repair_turns": decision.max_repair_turns,
        }),
    );
}
```

