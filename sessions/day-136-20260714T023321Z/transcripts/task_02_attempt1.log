```rust
#[test]
fn why_last_failure_cold_start_vs_healthy() {
    // Cold start: RunStarted but no RunCompleted and no FailureObserved
    let cold_events = vec![
        event("evt-1", "RunStarted", "run-1", json!({})),
    ];
    let cold_result = build_why_report(&cold_events, "last-failure");
    assert!(cold_result.is_err(), "cold start should produce error (no failure found)");
    let cold_msg = cold_result.unwrap_err();
    assert!(
        cold_msg.contains("no sessions have completed"),
        "cold-start message should mention no completed sessions, got: {cold_msg}"
    );

    // Healthy: RunCompleted exists but no FailureObserved
    let healthy_events = vec![
        event("evt-1", "RunStarted", "run-1", json!({})),
        event("evt-2", "RunCompleted", "run-1", json!({"outcome": "success"})),
    ];
    let healthy_result = build_why_report(&healthy_events, "last-failure");
    assert!(healthy_result.is_err(), "healthy should produce error (no failure found)");
    let healthy_msg = healthy_result.unwrap_err();
    assert!(
        healthy_msg.contains("successful session") || healthy_msg.contains("No failure data"),
        "healthy message should mention success, got: {healthy_msg}"
    );

    // With failure: should succeed
    let failure_events = vec![
        event("evt-1", "RunStarted", "run-1", json!({})),
        event("evt-2", "FailureObserved", "run-1", json!({"reason": "test failure"})),
    ];
    let failure_result = build_why_report(&failure_events, "last-failure");
    assert!(failure_result.is_ok(), "failure events should produce a report");

    // Verify cold and healthy messages are different
    assert_ne!(cold_msg, healthy_msg, "cold-start and healthy messages must differ");
}
```

