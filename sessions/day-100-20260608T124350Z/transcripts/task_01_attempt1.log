I think the simplest approach that fulfills the task:

```rust
thread_local! {
    static LAST_RUN_ERROR: std::cell::Cell<Option<String>> = std::cell::Cell::new(None);
}

pub fn store_run_error(msg: &str) {
    LAST_RUN_ERROR.with(|cell| {
        cell.set(Some(msg.to_string()));
    });
}

pub fn run_completed_payload(status: &str, error: Option<&str>) -> Value {
    let mut payload = json!({
        "status": status,
        "completed_at_ms": now_ms(),
    });
    if let Some(msg) = error {
        payload["error"] = json!(msg);
    }
    payload
}

pub fn mark_run_completed_with_error(msg: &str) {
    store_run_error(msg);
    let err = LAST_RUN_ERROR.with(|cell| cell.take());
    record(
        EventType::RunCompleted,
        Actor::Harness,
        run_completed_payload("error", err.as_deref()),
    );
}

pub fn mark_run_completed(status: &str) {
    record(
        EventType::RunCompleted,
        Actor::Harness,
        run_completed_payload(status, None),
    );
}
```

Then in `exit_with_state`:
