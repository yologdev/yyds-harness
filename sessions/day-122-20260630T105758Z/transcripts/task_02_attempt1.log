```rust
fn read_tail(path: &Path, limit: usize) -> Result<Vec<String>, std::io::Error> {
    use std::io::{BufRead, Read, Seek, SeekFrom};
    
    let mut file = std::fs::File::open(path)?;
    let file_size = file.seek(SeekFrom::End(0))? as usize;
    
    if file_size == 0 {
        return Ok(Vec::new());
    }
    
    // Estimate bytes to read: assume ~1KB per line, but cap at 8MB
    let estimated_bytes = (limit * 1024).min(8 * 1024 * 1024);
    let mut read_size = estimated_bytes.min(file_size);
    
    let mut buf_reader;
    let mut lines: Vec<String>;
    
    loop {
        let seek_pos = file_size - read_size;
        let mut file = std::fs::File::open(path)?;
        file.seek(SeekFrom::Start(seek_pos as u64))?;
        
        buf_reader = std::io::BufReader::new(file);
        
        // Skip the first partial line if we didn't seek to the beginning
        if seek_pos > 0 {
            let mut skip = String::new();
            buf_reader.read_line(&mut skip)?;
        }
        
        lines = Vec::with_capacity(limit + 1);
        for line in buf_reader.lines() {
            let line = line?;
            if lines.len() >= limit {
                lines.remove(0);
            }
            lines.push(line);
        }
        
