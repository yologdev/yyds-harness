```rust
fn read_tail(path: &Path, limit: usize) -> Result<Vec<String>, std::io::Error> {
    use std::io::{Read, Seek, SeekFrom};
    
    let mut file = std::fs::File::open(path)?;
    let file_size = file.seek(SeekFrom::End(0))?;
    
    // Estimate: average line is ~500 bytes, so we need at most limit * 500 bytes.
    // Use a larger estimate (2KB per line) to be safe.
    const MAX_LINE_BYTES: usize = 2048;
    let mut buf_size = (limit + 1) * MAX_LINE_BYTES;
    if buf_size > file_size as usize {
        buf_size = file_size as usize;
    }
    
    let seek_pos = file_size - buf_size as u64;
    file.seek(SeekFrom::Start(seek_pos))?;
    
    let mut buf = vec![0u8; buf_size];
    file.read_exact(&mut buf)?;
    
    let text = String::from_utf8_lossy(&buf);
    let mut lines: Vec<String> = text.lines().map(|s| s.to_string()).collect();
    
    // If we didn't get enough lines, read more.
    // ...
    
    // Keep only the last `limit` lines
    if lines.len() > limit {
        lines = lines.split_off(lines.len() - limit);
    }
    
    Ok(lines)
}
```

