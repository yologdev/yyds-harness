fn read_tail(path: &Path, limit: usize) -> Result<Vec<String>, std::io::Error> {
    use std::collections::VecDeque;
    use std::io::{BufRead, Seek, SeekFrom};
    
    let file = std::fs::File::open(path)?;
    let file_size = file.seek(SeekFrom::End(0))? as usize;
    
    if file_size == 0 {
        return Ok(Vec::new());
    }
    
    // Estimate: each line averages ~500 bytes but can be much longer for JSON payloads.
    // Read in chunks and double the window if we don't have enough lines.
    // Start with a window that should cover limit lines at ~1KB each, capped at 8MB.
    let mut read_size = (limit * 1024).min(8 * 1024 * 1024).min(file_size);
    
    loop {
        let seek_pos = file_size - read_size;
        let mut file = std::fs::File::open(path)?;
        file.seek(SeekFrom::Start(seek_pos as u64))?;
        
        let mut reader = std::io::BufReader::new(file);
        
        // Skip the first (possibly partial) line unless we're at file start
        if seek_pos > 0 {
            let mut skip = String::new();
            reader.read_line(&mut skip)?;
        }
        
        let mut lines: VecDeque<String> = VecDeque::with_capacity(limit + 1);
        for line_result in reader.lines() {
            let line = line_result?;
            if lines.len() >= limit {
                lines.pop_front();
            }
            lines.push_back(line);
        }
        
        if lines.len() >= limit || read_size >= file_size {
            return Ok(lines.into_iter().collect());
        }
        
        // Not enough lines — double the window
        read_size = (read_size * 2).min(file_size);
    }
}
