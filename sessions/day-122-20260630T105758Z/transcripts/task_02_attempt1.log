```rust
fn read_tail(path: &Path, limit: usize) -> Result<Vec<String>, std::io::Error> {
    use std::io::{BufRead, Seek, SeekFrom};
    
    let file = std::fs::File::open(path)?;
    let file_size = file.seek(SeekFrom::End(0))?;
    
    // Buffer size: estimate each line at ~1KB, read up to 1MB
    let estimated_bytes = (limit * 1024).min(1_048_576);
    let read_size = estimated_bytes.min(file_size as usize);
    
    let mut reader = std::io::BufReader::new(file);
    reader.seek(SeekFrom::Start(file_size - read_size as u64))?;
    
    // Skip the first (possibly partial) line
    let mut first_line = String::new();
    reader.read_line(&mut first_line)?;
    
    // Read remaining lines
    let mut lines = Vec::with_capacity(limit);
    for line in reader.lines() {
        let line = line?;
        lines.push(line);
        if lines.len() > limit {
            lines.remove(0);
        }
    }
    
    Ok(lines)
}
```

