For the `run_command_with_timeout` function, the implementation:
```rust
pub fn run_command_with_timeout(
    command: &str,
    workdir: Option<&Path>,
    timeout_secs: u64,
) -> (bool, String, String) {
    let started = Instant::now();
    let mut cmd = Command::new("/bin/sh");
    cmd.arg("-lc").arg(command);
    if let Some(workdir) = workdir {
        cmd.current_dir(workdir);
    }
    
    // Spawn the child
    let mut child = match cmd.spawn() {
        Ok(child) => child,
        Err(e) => {
            return (
                false,
                String::new(),
                e.to_string(),
            );
        }
    };
    
    // Wrap in a thread with channel
    let (tx, rx) = std::sync::mpsc::channel();
    std::thread::spawn(move || {
        let output = child.wait_with_output();
        let _ = tx.send(output);
    });
    
    match rx.recv_timeout(Duration::from_secs(timeout_secs)) {
        Ok(Ok(output)) => {
            // ... build normal result
        }
        Ok(Err(e)) => {
            // ... error result
        }
        Err(std::sync::mpsc::RecvTimeoutError::Timeout) => {
            // Kill child
        }
    }
}
```

I need to be careful: `child` is moved into the thread, so I can't kill it from the parent. I need to record the PID first.

Let me use this pattern:
```rust
let mut child = cmd.spawn()?;
let pid = child.id();
let (tx, rx) = std::sync::mpsc::channel();
std::thread::spawn(move || {
    let output = child.wait_with_output();
    let _ = tx.send(output);
});

match rx.recv_timeout(Duration::from_secs(timeout_secs)) {
    Ok(Ok(output)) => { ... }
    Err(_) => {
        // Kill by PID
        let _ = Command::new("kill").arg("-9").arg(pid.to_string()).output();
        // Return timeout failure
    }
}
```

