let (tx, rx) = std::sync::mpsc::channel();
let cmd_str = command.to_string();
let handle = std::thread::spawn(move || {
    let output = Command::new("/bin/sh").arg("-lc").arg(&cmd_str).output();
    tx.send(output).ok();
});
match rx.recv_timeout(Duration::from_secs(timeout)) {
    Ok(output_result) => { /* handle normally */ }
    Err(_) => { /* timed out, kill child */ }
}
```

Wait, but `thread::spawn` with `move` and then killing the child if it times out — I can't kill the child from the parent thread easily because `Command` is moved into the thread. I'd need to keep a reference to the child PID.

Actually, the simplest pattern: spawn the process in the parent, then use a thread to wait for it:

```rust
let mut child = cmd.spawn()?;
let (tx, rx) = mpsc::channel();
let handle = thread::spawn(move || {
    let result = child.wait_with_output();
    tx.send(result).ok();
});

match rx.recv_timeout(Duration::from_secs(timeout)) {
    Ok(output_result) => { /* normal flow */ }
    Err(_) => {
        // Timed out — kill the child
        let _ = child.kill();
        let _ = child.wait();
        return FixtureCommandResult { passed: false, ... "timed out" };
    }
}
```

But `child` is moved into the thread... I need the PID before moving. Let me think...

Actually, I can get the PID first, then move, then kill by PID if timeout:

```rust
let mut child = cmd.spawn()?;
let pid = child.id();
let (tx, rx) = mpsc::channel();
thread::spawn(move || {
    let result = child.wait_with_output();
    tx.send(result).ok();
});

match rx.recv_timeout(Duration::from_secs(timeout)) {
    Ok(output_result) => { /* normal */ }
    Err(_) => {
        // Kill by PID
        let _ = Command::new("kill").arg("-9").arg(pid.to_string()).output();
        return FixtureCommandResult { passed: false, stderr_preview: "command timed out after Ns" };
    }
}
```

