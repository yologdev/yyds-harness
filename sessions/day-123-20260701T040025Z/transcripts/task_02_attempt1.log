fn handle_cache_report(args: &[String]) {
    let path = default_events_path();
    
    // Count total events (fast line count)
    let total_events = match std::fs::read_to_string(&path) {
        Ok(raw) => raw.lines().filter(|l| !l.trim().is_empty()).count(),
        Err(_) => 0,
    };
    
    let mut sampled = false;
    let events = if total_events > CACHE_REPORT_EVENT_LIMIT {
        sampled = true;
        match read_tail_cache_events(&path, CACHE_REPORT_EVENT_LIMIT) {
            Ok(events) => events,
            Err(_) => {
                // Fall back to SQLite or give up
                ...
            }
        }
    } else {
        // File is small enough to read entirely
        match read_events(&path) {
            Ok(events) => events,
            Err(_) => match read_events_from_sqlite(&path) {
                Ok(events) => { ... }
                Err(e) => { ... return; }
            }
        }
    };
    
    match build_cache_report(&events) {
        Ok(report) if args.iter().any(|arg| arg == "--json") => ...
        Ok(report) => println!("{}", render_cache_report(&report, sampled, total_events, CACHE_REPORT_EVENT_LIMIT)),
        Err(e) => eprintln!("{YELLOW}  {e}{RESET}"),
    }
}
```

3. Add a `read_tail_cache_events` helper:
```rust
fn read_tail_cache_events(path: &Path, limit: usize) -> Result<Vec<Value>, std::io::Error> {
    let raw = std::fs::read_to_string(path)?;
    let mut lines = VecDeque::new();
    for line in raw.lines() {
        lines.push_back(line.to_string());
        if lines.len() > limit {
            lines.pop_front();
        }
    }
    let mut events = Vec::with_capacity(lines.len());
    for line in &lines {
        // Use compatibility normalization
        let normalized = crate::state::compatibility_event_json_line(line).ok();
        if let Some(ref n) = normalized {
            if let Ok(value) = serde_json::from_str::<Value>(n) {
                events.push(value);
            }
        } else if let Ok(value) = serde_json::from_str::<Value>(line) {
            events.push(value);
        }
    }
    Ok(events)
}
```

