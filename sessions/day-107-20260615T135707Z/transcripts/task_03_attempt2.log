    age_minutes = int((snapshot_time - most_recent_ts).total_seconds() / 60)
    
    if sessions_behind <= 1:
        return f"Snapshot age: {age_minutes}m ({sessions_behind} session(s) behind) — reliable ✓"
    else:
        return f"Snapshot age: {age_minutes}m ({sessions_behind} sessions behind) — treat with caution ⚠"
