def compute_freshness(audit_dir: Path, snapshot_time: datetime) -> str:
    """Return a freshness indicator line for the trajectory header."""
    sessions = ordered_sessions(audit_dir)
    if not sessions:
        return "Snapshot age: unknown (no audit-log sessions) — treat with caution"
    
    # Count sessions whose timestamp is newer than the snapshot
    sessions_behind = 0
    most_recent_ts = None
    for session_dir in sessions:
        # Parse timestamp from directory name like day-107-20260615T130431Z
        name = session_dir.name
        # Extract the timestamp part after the day number
        parts = name.split('-')
        if len(parts) >= 3:
            ts_str = parts[-1]  # e.g., 20260615T130431Z
            try:
                ts = datetime.strptime(ts_str, "%Y%m%dT%H%M%SZ").replace(tzinfo=timezone.utc)
                if ts > snapshot_time:
                    sessions_behind += 1
                most_recent_ts = ts
