Let me write the function:

```python
def compute_freshness(audit_dir: Path) -> str:
    """Return a one-line freshness indicator for the YOUR TRAJECTORY header.
    Compares the most recent session timestamp against now to show how stale
    the trajectory evidence may be."""
    sessions = ordered_sessions(audit_dir)
    if not sessions:
        return "Snapshot age: N/A (no audit data)"
    
    now_utc = datetime.now(timezone.utc)
    
    # Get the most recent session timestamp
    newest_session = sessions[-1]
    try:
        outcome = json.loads((newest_session / "outcome.json").read_text(errors="replace"))
    except (OSError, json.JSONDecodeError, UnicodeDecodeError) as e:
        warn(f"could not read newest outcome for freshness: {e}")
        return "Snapshot age: N/A (unreadable audit data)"
    
    newest_ts = str(outcome.get("ts") or "").strip()
    if not newest_ts:
        return "Snapshot age: N/A (missing session timestamp)"
    
    try:
        newest_dt = datetime.fromisoformat(newest_ts.replace("Z", "+00:00"))
    except ValueError:
        return "Snapshot age: N/A (unparseable session timestamp)"
    
    # Count sessions whose timestamp is newer than now (should be 0 normally)
    sessions_behind = 0
    for session in sessions:
        try:
            outcome_data = json.loads((session / "outcome.json").read_text(errors="replace"))
            session_ts = str(outcome_data.get("ts") or "").strip()
            if session_ts:
                session_dt = datetime.fromisoformat(session_ts.replace("Z", "+00:00"))
                if session_dt > now_utc:
                    sessions_behind += 1
        except Exception:
            pass
    
    gap = now_utc - newest_dt
    gap_minutes = int(gap.total_seconds() / 60)
    
    if sessions_behind <= 1:
        # Fresh
        if gap_minutes < 60:
            age_str = f"{gap_minutes}m"
        elif gap_minutes < 1440:
            age_str = f"{gap_minutes // 60}h{gap_minutes % 60}m"
        else:
            days = gap_minutes // 1440
            hours = (gap_minutes % 1440) // 60
            age_str = f"{days}d{hours}h"
        return f"Snapshot age: {age_str} (fresh) — reliable"
    else:
        if gap_minutes < 60:
            age_str = f"{gap_minutes}m"
        elif gap_minutes < 1440:
            age_str = f"{gap_minutes // 60}h{gap_minutes % 60}m"
        else:
            days = gap_minutes // 1440
            hours = (gap_minutes % 1440) // 60
            age_str = f"{days}d{hours}h"
        return f"Snapshot age: {age_str} ({sessions_behind} sessions behind) — treat with caution"
```

