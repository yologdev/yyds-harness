```python
def classify_empty_session_reason(session_dir, outcome):
    """Classify why a session with zero landed tasks was empty.
    
    Returns one of: 'assessment_empty', 'reverted_no_edit', 'implementation_failed', 'unknown'.
    """
    attempted = outcome.get("tasks_attempted", 0)
    succeeded = outcome.get("tasks_succeeded", 0)
    reverted = outcome.get("reverted", False)
    
    # Check if tasks were selected via gnomes
    selected = 0
    if session_dir:
        gnomes = corrected_latest_gnomes(session_dir)
        selected = int_metric(gnomes, "selected_task_count")
    
    if attempted == 0:
        if selected == 0:
            return "assessment_empty"
        elif reverted:
            return "reverted_no_edit"
        else:
            return "assessment_empty"  # selected but never attempted, not reverted
    else:
        # attempted > 0 but succeeded == 0
        if reverted:
            # Check if any files were actually touched
            if _session_had_file_edits(session_dir):
                return "implementation_failed"
            else:
                return "reverted_no_edit"
        else:
            return "implementation_failed"
```

