Let me implement this:

```python
_git_tracked_cache: set[str] | None = None

def _git_tracked_files() -> set[str]:
    """Return the set of git-tracked files (cached)."""
    global _git_tracked_cache
    if _git_tracked_cache is not None:
        return _git_tracked_cache
    try:
        import subprocess
        result = subprocess.run(
            ["git", "ls-files"],
            capture_output=True, text=True, timeout=10,
        )
        if result.returncode == 0:
            _git_tracked_cache = set(result.stdout.splitlines())
        else:
            _git_tracked_cache = set()
    except Exception:
        _git_tracked_cache = set()
    return _git_tracked_cache

def _file_is_tracked(path: str) -> bool:
    """Return True if path is tracked by git."""
    return path in _git_tracked_files()

def _candidate_files_exist(candidate: dict[str, object]) -> bool:
    """Return True if at least one file listed in the candidate's files field exists AND is git-tracked."""
    files_str = str(candidate.get("files") or "")
    tracked = _git_tracked_files()
    for path in files_str.split(","):
        path = path.strip()
        if not path:
            continue
        if os.path.isfile(path) and path in tracked:
            return True
    return False
```

Wait, but the task says: "If git is not available (unlikely in this repo), fall back to the existing file-existence check rather than blocking task selection entirely."

Let me handle that: if `git ls-files` fails, we should fall back to the regular file-existence check. When I cache the git output as an empty set, the check would return False for all files, which would block all tasks. That's wrong.

Let me handle this better:

```python
_GIT_AVAILABLE: bool | None = None
_git_tracked_cache: set[str] | None = None

def _git_tracked_files() -> set[str] | None:
    """Return the set of git-tracked files (cached), or None if git unavailable."""
    global _git_tracked_cache, _GIT_AVAILABLE
    if _GIT_AVAILABLE is False:
        return None
    if _git_tracked_cache is not None:
        return _git_tracked_cache
    try:
        import subprocess
        result = subprocess.run(
            ["git", "ls-files"],
            capture_output=True, text=True, timeout=10,
        )
        if result.returncode == 0:
            _GIT_AVAILABLE = True
            _git_tracked_cache = set(result.stdout.splitlines())
            return _git_tracked_cache
        else:
            _GIT_AVAILABLE = False
            return None
    except Exception:
        _GIT_AVAILABLE = False
        return None

def _candidate_files_exist(candidate: dict[str, object]) -> bool:
    """Return True if at least one file listed in the candidate's files field exists.
    
    When git is available, only git-tracked files are counted.
    When git is unavailable, falls back to plain file existence.
    """
    files_str = str(candidate.get("files") or "")
    tracked = _git_tracked_files()
    for path in files_str.split(","):
        path = path.strip()
        if not path:
            continue
        if not os.path.isfile(path):
            continue
        if tracked is not None and path not in tracked:
            continue  # exists but not git-tracked; skip
        return True
    return False
```

