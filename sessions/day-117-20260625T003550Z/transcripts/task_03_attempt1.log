fn read_limited_events(path: &Path, limit: usize) -> Result<Vec<Value>, std::io::Error> {
    let mut events = read_events(path)?;
    if limit > 0 && events.len() > limit {
        let keep_from = events.len() - limit;
        events = events.split_off(keep_from);
    }
    Ok(events)
}
```

