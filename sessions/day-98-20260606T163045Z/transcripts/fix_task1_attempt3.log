fn handle_doctor() {
    println!("{BOLD}State Doctor{RESET}");
    
    let events_path = default_events_path();
    let store_path = default_store_path(&events_path);
    
    // --- Events ---
    let (total_events, runs_started, runs_completed, runs_failed, type_counts, failures) = 
        match read_events(&events_path) {
            Ok(events) => {
                let total = events.len();
                let mut started = 0u64;
                let mut completed = 0u64;
                let mut failed = 0u64;
                let mut types: BTreeMap<String, u64> = BTreeMap::new();
                let mut recent_failures: Vec<(String, String)> = Vec::new();
                
                for ev in &events {
                    let typ = ev.get("type").and_then(|v| v.as_str()).unwrap_or("unknown");
                    *types.entry(typ.to_string()).or_default() += 1;
                    
                    match typ {
                        "RunStarted" => started += 1,
                        "RunCompleted" => {
                            completed += 1;
                            let status = ev.get("status").and_then(|v| v.as_str()).unwrap_or("");
                            if status == "failed" {
                                failed += 1;
                                let ts = ev.get("ts").and_then(|v| v.as_str()).unwrap_or("?");
                                let run_id = ev.get("run_id").and_then(|v| v.as_str()).unwrap_or("?");
                                recent_failures.push((ts.to_string(), run_id.to_string()));
                            }
                        }
                        _ => {}
                    }
                }
                
                // Sort failures by ts descending, take last 5
                recent_failures.sort_by(|a, b| b.0.cmp(&a.0));
                recent_failures.truncate(5);
                
                (total, started, completed, failed, types, recent_failures)
            }
            Err(e) => {
                eprintln!("{RED}  Events: error reading {} — {e}{RESET}", events_path.display());
                (0, 0, 0, 0, BTreeMap::new(), Vec::new())
            }
        };
    
    let runs_total = runs_completed; // or runs_started? The task says "48 runs"
    // Actually looking at the output format: "Events: 265 total (48 runs, 0 failures)"
    // "runs" probably means RunCompleted, and "failures" means RunCompleted with failed status
    // Actually "runs" could mean RunStarted count. Let me use runs_started for "runs" count.
    
    // --- Events line ---
    let events_status = if total_events > 0 { GREEN } else { YELLOW };
    println!("  {events_status}Events:{RESET}    {total_events} total ({runs_started} runs, {runs_failed} failures)");
    
    // --- Store (SQLite) ---
    let store_status: &'static str;
    let store_schema: String;
    let store_ok: bool;
    
    if store_path.exists() {
        match Connection::open(&store_path) {
            Ok(conn) => {
                match conn.pragma_query_value(None, "integrity_check", |row| row.get::<_, String>(0)) {
                    Ok(ref integrity) if integrity == "ok" => {
                        store_ok = true;
                    }
                    Ok(ref bad) => {
                        store_ok = false;
                        store_status = "integrity";
                        store_schema = format!("integrity check: {bad}");
                    }
                    Err(e) => {
                        store_ok = false;
                        store_status = "error";
                        store_schema = format!("pragma failed: {e}");
                    }
                }
                
                if store_ok {
                    // Get user_version for schema version
                    match conn.pragma_query_value(None, "user_version", |row| row.get::<_, i64>(0)) {
                        Ok(version) => {
                            let current = crate::state::STATE_SQLITE_SCHEMA_VERSION;
                            let ver_str = if version == current as i64 {
                                format!("version {version} (current)")
                            } else {
                                format!("version {version} (current={current})")
                            };
                            store_status = "ok";
                            store_schema = format!("SQLite {ver_str} — integrity OK");
                        }
                        Err(e) => {
                            store_status = "warn";
                            store_schema = format!("SQLite — integrity OK, schema version error: {e}");
                        }
                    }
                }
            }
            Err(e) => {
                store_ok = false;
                store_status = "error";
                store_schema = format!("cannot open: {e}");
            }
        }
    } else {
        store_ok = false;
        store_status = "none";
        store_schema = "not found".to_string();
    }
    
    // ... hmm, let me think about this differently.
}
