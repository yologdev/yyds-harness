```rust
/// Check for unbounded recursive commands that may timeout.
/// Detects `find /`, `grep -r /`, `rg /` without bounds.
fn check_unbounded_command(cmd: &str) -> Option<String> {
    let cmd_lower = cmd.to_lowercase();
    let tokens: Vec<&str> = cmd.split_whitespace().collect();
    if tokens.is_empty() {
        return None;
    }

    let prog = tokens[0];

    match prog {
        "find" => {
            // Find the first non-flag path argument
            let mut path: Option<&str> = None;
            let mut has_maxdepth = false;
            for t in &tokens[1..] {
                if *t == "-maxdepth" || t.starts_with("-maxdepth=") {
                    has_maxdepth = true;
                } else if !t.starts_with('-') && path.is_none() {
                    path = Some(t);
                }
            }
            if !has_maxdepth {
                if let Some(p) = path {
                    if is_root_or_home(p) {
                        return Some(format!(
                            "Unbounded command: 'find {}' without -maxdepth may scan the entire filesystem and timeout. Add '-maxdepth N' or narrow the path.",
                            p
                        ));
                    }
                }
            }
        }
        "grep" => {
            let is_recursive = tokens[1..].iter().any(|t| *t == "-r" || *t == "-R" || *t == "--recursive");
            if is_recursive {
                for t in &tokens[2..] {
                    if is_root_or_home(t) {
                        return Some(format!(
                            "Unbounded command: 'grep -r {}' may scan the entire filesystem and timeout. Add '--max-depth N' or narrow the path.",
                            t
                        ));
                    }
                }
            }
        }
        "rg" => {
            // rg pattern [path...] — flag if any path is root/home
            // Skip tokens that start with - (flags)
            // First non-flag token after rg is the pattern, remaining are paths
            let mut seen_pattern = false;
            for t in &tokens[1..] {
                if t.starts_with('-') {
                    continue;
                }
                if !seen_pattern {
                    seen_pattern = true;
                    continue;
                }
                // This is a path argument
                if is_root_or_home(t) {
                    return Some(format!(
                        "Unbounded command: 'rg ... {}' may scan the entire filesystem and timeout. Add '--max-depth N' or narrow the path.",
                        t
                    ));
                }
            }
        }
        _ => {}
    }

    None
}

fn is_root_or_home(s: &str) -> bool {
    matches!(s, "/" | "~" | "~/" | "$HOME" | "$HOME/" | "${HOME}" | "${HOME}/")
}
```

