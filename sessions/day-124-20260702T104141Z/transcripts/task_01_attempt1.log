```rust
fn read_tail(path: &Path, limit: usize) -> Result<Vec<String>, std::io::Error> {
    use std::io::{Read, Seek, SeekFrom};
    
    let mut file = std::fs::File::open(path)?;
    let file_len = file.metadata()?.len();
    
    // For large files, read only from near the end.
    // Estimate: allow 8KB per line to be safe with variable-length JSON.
    let chunk_size = (8 * 1024 * limit as u64).min(file_len);
    
    let start_pos = file_len.saturating_sub(chunk_size);
    file.seek(SeekFrom::Start(start_pos))?;
    
    let mut buf = vec![0u8; chunk_size as usize];
    file.read_exact(&mut buf)?;
    
    let raw = String::from_utf8_lossy(&buf);
    let mut lines: Vec<&str> = raw.lines().collect();
    
    // If we started mid-file, the first line is partial - skip it
    if start_pos > 0 && !lines.is_empty() {
        lines.remove(0);
    }
    
    let start = if lines.len() > limit { lines.len() - limit } else { 0 };
    Ok(lines[start..].iter().map(|s| s.to_string()).collect())
}
```

